# Environment variables for local Docker Compose runs.
#
# Copy this file to .env.local and fill in real values:
#   cp .env.example .env.local
#
# .env.local is git-ignored. Docker Compose injects these into the nakama
# container, and main.go reads HIRO_LICENSE from the OS env before falling back
# to local.yml's runtime.env.

# Hiro license key (JWT). Required for the plugin to initialise Hiro.
HIRO_LICENSE=